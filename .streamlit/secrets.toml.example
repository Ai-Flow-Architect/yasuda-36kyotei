# Streamlit Cloud の「App settings → Secrets」にこの内容をコピーして設定する
# 実際の値を入れた secrets.toml は絶対に Git にコミットしないこと（.gitignoreで除外済み）

# アプリアクセスパスワード（クライアントログイン用）
password = "your-app-password"

# Yahoo Japan IMAP 設定
# - サーバー: imap.mail.yahoo.co.jp:993 (SSL)
# - 米国IPからの接続にはアクセスキー（IMAP/POP/SMTP用パスワード）が必要な場合あり
#   Yahoo!メール設定 → IMAP/POP/SMTPアクセス → アクセスキー発行で取得
yahoo_user = "your-account@yahoo.co.jp"
yahoo_password = "yahoo-imap-app-password-or-access-key"

# 送信者情報（メール本文フッター）
# ※ 日本語キーは TOML 仕様により必ず "..." で囲むこと（クォーテッドキー）
#   囲まないと Streamlit Cloud Secrets が "Invalid format: please enter valid TOML." で弾く
"差出人名" = "山田太郎"
"差出人所属" = "○○事務所"
"差出人電話" = "03-xxxx-xxxx"
