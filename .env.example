# ============================================
# yasuda-36kyotei - 環境変数テンプレート
# ============================================
# このファイルを `.env` にコピーして実値を記入してください
#
# 使い方:
#   cp .env.example .env
#   # 値を埋めたあと:
#   streamlit run app.py
#
# 本番環境では Streamlit Cloud Secrets を使用

# --- SMTP (Office365想定) ---
SMTP_SERVER=smtp.office365.com
SMTP_PORT=587
# 送信元メールアドレス
SMTP_USER=
# Microsoft 365 のアプリパスワード（通常PW不可）
# 取得: https://account.microsoft.com/security
SMTP_PASSWORD=
# Fromヘッダーに表示するメールアドレス（SMTP_USERと同じでOK）
SMTP_FROM=
# Office365 アプリパスワード（互換用・SMTP_PASSWORDと同値）
APP_PASSWORD=
